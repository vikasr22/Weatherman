{
    "include": [
        "./src/**/*"
    ],
    "compilerOptions": {
        "strict": true,
        "esModuleInterop": true,
        "lib": [
            "dom",
            "es2015"
        ],
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "module": "esnext",
        "target": "es6",
        "ignoreDeprecations": "6.0"
    }
}